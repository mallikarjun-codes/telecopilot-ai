PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://telecopilot:telecopilot@localhost:5432/telecopilot"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Any OpenAI-compatible embeddings endpoint. The model is intentionally configurable.
EMBEDDING_API_KEY=replace-with-provider-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=replace-with-embedding-model

# OpenAI-compatible chat-completions API. Provider name is descriptive and replaceable.
LLM_PROVIDER=openai-compatible
LLM_API_KEY=replace-with-provider-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=replace-with-chat-model
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800

RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Conversation memory defaults to the last 10 user/assistant exchanges.
MAX_HISTORY_MESSAGES=20
AUTO_TITLE_LENGTH=60
MAX_CONVERSATION_MESSAGES=1000

# Optional token pricing used to estimate per-answer cost.
LLM_INPUT_COST_PER_MILLION=0
LLM_OUTPUT_COST_PER_MILLION=0

# AI agent orchestration limits.
AGENT_MAX_HISTORY=20
AGENT_MAX_CONTEXT_CHUNKS=5
AGENT_MIN_CONFIDENCE=0.7
